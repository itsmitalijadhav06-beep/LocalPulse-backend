# LocalPulse Environment Variables Configuration Example

# App Configuration
PROJECT_NAME="LocalPulse API"
ENV="development"
DEBUG=true
API_V1_STR="/api/v1"
HOST="127.0.0.1"
PORT=8000

# CORS Settings (JSON-encoded array of origins)
CORS_ORIGINS='["http://localhost:3000", "http://127.0.0.1:3000"]'

# JWT Security
SECRET_KEY="super-secret-jwt-key-change-this-in-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days

# MongoDB Configuration (Placeholder/Unused)
MONGODB_URI="mongodb://localhost:27017"
MONGODB_DB_NAME="localpulse_db"

# Cloudinary Integration (Placeholder/Unused)
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Gemini AI Integration (Placeholder/Unused)
GEMINI_API_KEY="your-gemini-api-key"
